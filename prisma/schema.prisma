// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model AuditLog {
  id          String    @id @default(uuid())
  action      String    // CREATE, UPDATE, DELETE, READ
  entity      String    // resource name (e.g. "User", "Task")
  entityId    String?   // specific record affected (optional)
  beforeState Json?     // snapshot before change
  afterState  Json?     // snapshot after change
  ipAddress   String?   // request origin
  deviceInfo  String?   // browser, OS, app version
  location    String?   // optional: resolved from IP
  reason      String?   // optional explanation
  timestamp   DateTime  @default(now())
}

